{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Claude Chat MCP",
  "version": "0.9.0",
  "identifier": "com.huylq98.claudechatmcp",
  "build": {
    "frontendDist": "ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Claude Chat MCP",
        "width": 900,
        "height": 700,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis", "dmg", "deb", "appimage"],
    "icon": ["icons/icon.png", "icons/icon.ico", "icons/icon.icns"],
    "macOS": {
      "minimumSystemVersion": "12.0"
    }
  }
}
